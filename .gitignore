# Local environment
.env
.env.local

# data/ is populated by `python scripts/download_from_hf.py`.
# Only the aggregated judgments CSV is committed to the repo (it contains
# no sensitive information and lets reviewers inspect the main results
# without downloading the full dataset).
/data/*
!/data/eval_results
/data/eval_results/*
!/data/eval_results/judgments_aggregated.csv

